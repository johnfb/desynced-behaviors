behavior Formation Hold(Anchor, Offset*, Radius, Tolerance):

unlock()
get_location(Unit=Anchor, Coord=$AnchorPos)
is_empty(Value=Offset)  >NEXT (Empty) >add (Has Value)
random_coordinate(Coordinate=Anchor, Range=Radius, Result=Offset)
sub(From=Offset, Num=$AnchorPos, Result=Offset)
set_number(Value=Offset, Number=Tolerance, Result=Offset)
add:
add(To=$AnchorPos, Num=Offset, Result=$Spot)
get_distance(Target=$Spot, Distance=$DST)
check_number(Value=$DST, Compare=Tolerance)  >NEXT (If Larger) >POP (If Smaller) >POP (If Equal)
domove(Target=$Spot, c=2)  >POP (Path Blocked) >POP (next)