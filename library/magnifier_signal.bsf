behavior MagnifierSignal(Resource):
  desc: "Periodically check Resource nodes within range, tracking two INDEPENDENT conditions per node -- needs regen (below the 200 cap) and worth mining (above the 100 floor). Power (shutdown/turnon) follows the regen condition only; the drone-invitation signal (id=Resource, num=-1, a value deliberately reserved for this and never used by the Hauler-facing num=0/num>0 pickup/dropoff convention Mining Leader/Follower and Fendersons Transport already use on this same Resource id) follows the mining condition only. Keeping these separate avoids a deadlock: an abundant, never-mined area (all nodes already above 200) still needs to invite drones even though it needs no regen at all."

unlock()
label_arrow_right:
label(Label=v_arrow_right)
  cmt="""Poll nearby Resource nodes; manage power (regen cap) and drone invitation (mining floor) independently""";
wait(Time=20)
set_reg(Value=0, Target=$NeedsRegen)
set_reg(Value=0, Target=$Mineable)
for_entities_in_range(Range=2, Filter=v_resource, Filter2=Resource, Unit=$Node)  >check_number_2 (Done) >NEXT (next)
get_resource_num(Resource=$Node, Result=$Amt)
check_number(Value=$Amt, Compare=200)  >NEXT (If Larger) >set_reg (If Smaller) >NEXT (If Equal)
check_number:
check_number(Value=$Amt, Compare=100)  >NEXT (If Larger) >POP (If Smaller) >POP (If Equal)
set_reg(Value=1, Target=$Mineable)  >POP (next)
set_reg:
set_reg(Value=1, Target=$NeedsRegen)  >check_number (next)
check_number_2:
check_number(Value=$NeedsRegen, Compare=0)  >turnon (If Larger) >NEXT (If Smaller) >NEXT (If Equal)
shutdown()
check_number_3:
check_number(Value=$Mineable, Compare=0)  >set_number (If Larger) >NEXT (If Smaller) >NEXT (If Equal)
set_reg(Target=@signal)  >POP (next)
  cmt="""Nothing worth mining -- stop broadcasting""";
set_number:
set_number(Value=Resource, Number=-1, Result=@signal)  >POP (next)
  cmt="""num=-1: drone-only, never collides with the Hauler-facing num=0/num>0 convention""";
turnon:
turnon()  >check_number_3 (next)