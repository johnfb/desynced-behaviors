behavior Observer(Config*):
  desc: "Look for enemies, damaged units, infected units or dropped items; if on a bot optionally random walk or follow"
  keepvars: true

unlock()
call(Radar=$Radar, Index=c_portable_radar, Next Tick=$NextTick, Filter 1=v_enemy_faction, sub=1)
set_reg(Value=v_enemy_faction, Target=$NextTag)
set_reg(Value=0, Target=$CycleId)
set_reg(Value=1, Target=$WaitTarget)
get_self(Unit Reference=$Self)
get_unit_info(Unit=$Self, Result=$Vis, c=2)
  cmt="""Visibility range for the random-step radius""";
label_arrow_right:
label(Label=v_arrow_right)
  cmt="""Begin""";
sequence()  >NEXT (First) >get_closest_entity (Second) >POP (Third) >POP (Fourth) >jump (Last)
wait(Time=1)
set_reg(Target=$Tag)
call(Radar=$Radar, Index=c_portable_radar, Next Tick=$NextTick, Result=$Result, Tag=$Tag, Next Tag=$NextTag, sub=2)
unit_type(Unit=$Self)  >NEXT (Building) >POP (Bot) >NEXT (Construction) >NEXT (No Unit)
  cmt="""Only go to second if we are a bot""";
last()
get_closest_entity:
get_closest_entity(Filter=v_enemy_faction, Output=$Enemy)
  cmt="""Priority 1: enemy avoidance, unconditional""";
is_empty(Value=$Enemy)  >NEXT (Empty) >has_like_component (Has Value)
value_type(Data=Config)  >POP (Item) >get_distance (Unit) >POP (Component) >POP (Tech) >POP (Value) >NEXT (Coord) >NEXT (No Match)
  cmt="""
If Config is a unit, follow,
if it is a coordinate or empty, random walk
Otherwise, do nothing
""";
is_empty(Value=$WaitTarget)  >NEXT (Empty) >check_number (Has Value)
add:
add(To=$CycleId, Num=1, Result=$WaitTarget)  >POP (next)
  cmt="""Arm/re-arm: wait for the next full cycle""";
check_number:
check_number(Value=$CycleId, Compare=$WaitTarget)  >NEXT (If Larger) >POP (If Smaller) >NEXT (If Equal)
  cmt="""CycleId is only incremented when a full cycle of nothing found""";
is_empty(Value=Config)  >NEXT (Empty) >get_location (Has Value)
random_coordinate(Coordinate=$Self, Range=$Vis, Result=@goto)  >add (next)
  cmt="""Pure random walk""";
get_location:
get_location(Unit=$Self, Coord=$D)
  cmt="""Biased random walk; Config is last coordinate""";
sub(From=$D, Num=Config, Result=$A)
add(To=$A, Num=$D, Result=$A)
random_coordinate(Coordinate=$A, Range=$Vis, Result=@goto)
set_reg(Value=$D, Target=Config)  >add (next)
get_distance:
get_distance(Target=Config, Distance=$D)
check_number(Value=$D, Compare=Config)  >NEXT (If Larger) >moveaway_range (If Smaller) >POP (If Equal)
domove(Target=Config, c=2)  >NEXT (Path Blocked) >POP (next)
moveaway_range:
moveaway_range(Target=Config, c=2)  >POP (next)
has_like_component:
has_like_component(Component=c_alien_stealth)  >set_number (Failed) >NEXT (next)
set_number(Value=$Enemy, Number=10, Result=$Enemy)
  cmt="""Stealthed: splash-safety buffer only""";
moveaway_range_2:
moveaway_range(Target=$Enemy, c=2)  >POP (next)
set_number:
set_number(Value=$Enemy, Number=20, Result=$Enemy)  >moveaway_range_2 (next)
  cmt="""Not stealthed: full engagement-range standoff""";
jump:
jump(Label=$Tag)
jump(Label=v_arrow_right)  >POP (next) >label_arrow_right (jump→label)
  cmt="""Nothing new this tick, keep waiting""";
label_enemy_faction:
label(Label=v_enemy_faction)
  cmt="""Enemy result arrived""";
sequence()  >NEXT (First) >POP (Second) >POP (Third) >POP (Fourth) >jump_2 (Last)
is_empty(Value=$Result)  >NEXT (Empty) >set_reg (Has Value)
call(Radar=$Radar, Index=c_portable_radar, Next Tick=$NextTick, Filter 1=v_damaged, Filter 2=v_own_faction, sub=1)
set_reg(Value=v_damaged, Target=$NextTag)  >POP (next)
set_reg:
set_reg(Value=v_enemy_faction, Target=@visual)
set_reg(Value=$Result, Target=@signal)
simulation_tick(Tick=$Now)
sub(From=$Now, Num=$LastPingTick, Result=$A)
check_number(Value=$A, Compare=15)  >NEXT (If Larger) >POP (If Smaller) >NEXT (If Equal)
  cmt="""Ping throttle""";
ping(Target=$Result)
set_reg(Value=$Now, Target=$LastPingTick)  >POP (next)
jump_2:
jump(Label=v_arrow_right)  >POP (next) >label_arrow_right (jump→label)
label_damaged:
label(Label=v_damaged)
  cmt="""Damaged-friendly result arrived""";
sequence()  >NEXT (First) >POP (Second) >POP (Third) >POP (Fourth) >jump_3 (Last)
is_empty(Value=$Result)  >NEXT (Empty) >set_reg_2 (Has Value)
call(Radar=$Radar, Index=c_portable_radar, Next Tick=$NextTick, Filter 1=v_infected, Filter 2=v_own_faction, sub=1)
set_reg(Value=v_infected, Target=$NextTag)  >POP (next)
set_reg_2:
set_reg(Value=v_damaged, Target=@visual)
set_reg(Value=$Result, Target=@signal)
call:
call(Radar=$Radar, Index=c_portable_radar, Next Tick=$NextTick, Filter 1=v_enemy_faction, sub=1)
set_reg(Value=v_enemy_faction, Target=$NextTag)  >POP (next)
jump_3:
jump(Label=v_arrow_right)  >POP (next) >label_arrow_right (jump→label)
label_infected:
label(Label=v_infected)
  cmt="""Infected-friendly result arrived""";
sequence()  >NEXT (First) >POP (Second) >POP (Third) >POP (Fourth) >jump_4 (Last)
is_empty(Value=$Result)  >NEXT (Empty) >set_reg_3 (Has Value)
call(Radar=$Radar, Index=c_portable_radar, Next Tick=$NextTick, Filter 1=v_droppeditem, sub=1)
set_reg(Value=v_droppeditem, Target=$NextTag)  >POP (next)
set_reg_3:
set_reg(Value=v_infected, Target=@visual)
set_reg(Value=$Result, Target=@signal)  >call (next)
jump_4:
jump(Label=v_arrow_right)  >POP (next) >label_arrow_right (jump→label)
label_droppeditem:
label(Label=v_droppeditem)
  cmt="""Dropped-item result arrived""";
sequence()  >NEXT (First) >POP (Second) >POP (Third) >POP (Fourth) >jump_5 (Last)
is_empty(Value=$Result)  >NEXT (Empty) >set_reg_4 (Has Value)
add(To=$CycleId, Num=1, Result=$CycleId)
  cmt="""Only advance cycle if no step found anything""";
set_reg(Target=@signal)
set_reg(Target=@visual)  >call (next)
set_reg_4:
set_reg(Value=v_droppeditem, Target=@visual)
set_reg(Value=$Result, Target=@signal)  >call (next)
jump_5:
jump(Label=v_arrow_right)  >POP (next) >label_arrow_right (jump→label)

sub Async Radar Set(Radar*, Index, Next Tick*, Filter 1, Filter 2, Filter 3):
  desc: "Provide a way to setup a radar component asynchronously. Uses a memory array at index to store intermediate state. Does not support scout radars and falls back to visibility range."

has_like_component(Component=c_portable_radar)  >set_reg_8 (Failed) >NEXT (next)
  cmt="""Do we have a radar?""";
sequence()  >NEXT (First) >is_equipped (Second) >is_equipped_2 (Third) >POP (Fourth) >set_number (Last)
is_equipped(Component=Radar)  >NEXT (Component Equipped) >POP (next)
check_number(Value=Radar)  >NEXT (If Larger) >POP (If Smaller) >POP (If Equal)
last()
  cmt="""Our cached radar looks valid""";
is_equipped:
is_equipped(Component=c_radar)  >set_reg_3 (Component Equipped) >NEXT (next)
is_equipped(Component=c_small_radar)  >set_reg_2 (Component Equipped) >NEXT (next)
is_equipped(Component=c_portable_radar)  >set_reg (Component Equipped) >NEXT (next)
is_equipped(Component=c_radar_array)  >NEXT (Component Equipped) >POP (next)
set_reg(Value=c_radar_array[num=10], Target=Radar)
last()
set_reg:
set_reg(Value=c_portable_radar[num=2], Target=Radar)
last()
set_reg_2:
set_reg(Value=c_small_radar[num=10], Target=Radar)
last()
set_reg_3:
set_reg(Value=c_radar[num=10], Target=Radar)
last()
is_equipped_2:
is_equipped(Component=c_radar_suite)  >set_reg_7 (Component Equipped) >NEXT (next)
is_equipped(Component=c_alien_sensor)  >set_reg_6 (Component Equipped) >NEXT (next)
is_equipped(Component=c_alien_sensor_wide)  >set_reg_5 (Component Equipped) >NEXT (next)
is_equipped(Component=c_sensor_spike_comp)  >set_reg_4 (Component Equipped) >NEXT (next)
set_reg(Target=Radar)  >POP (next)
  cmt="""No supported radar found, clear cache and use fallback""";
set_reg_4:
set_reg(Value=c_sensor_spike_comp[num=5], Target=Radar)
last()
set_reg_5:
set_reg(Value=c_alien_sensor_wide[num=3], Target=Radar)
last()
set_reg_6:
set_reg(Value=c_alien_sensor[num=5], Target=Radar)
last()
set_reg_7:
set_reg(Value=c_radar_suite[num=10], Target=Radar)
last()
set_number:
set_number(Value=Index, Number=1, Result=$A)
  cmt="""Save the filter""";
memory_set(Index=$A, Value=Filter 1)
set_number(Value=Index, Number=2, Result=$A)
memory_set(Index=$A, Value=Filter 2)
set_number(Value=Index, Number=3, Result=$A)
memory_set(Index=$A, Value=Filter 3)
simulation_tick(Tick=$Tick)
is_empty(Value=Radar)  >NEXT (Empty) >add (Has Value)
set_reg(Value=$Tick, Target=Next Tick)  >POP (next)
add:
add(To=$Tick, Num=Radar, Result=Next Tick)
  cmt="""Compute the tick after which the radar will have its result""";
for_number(From=1, To=3, Value=$Num)  >POP (Done) >NEXT (next)
set_number(Value=Index, Number=$Num, Result=$A)
memory_get(Index=$A, Value=$B)
set_number(Value=Radar, Number=$Num, Result=$A)
set_comp_reg(Value=$B, To=$A)  >POP (next)
set_reg_8:
set_reg(Target=Radar)  >set_number (next)

sub Async Radar Get(Radar, Index, Next Tick*, Result*, Tag*, Next Tag):
  desc: "Provide a way to poll a radar component asynchronously. Falls back to visibility range when no radar equipped like the built in Radar instruction. Does not support scout radars and falls back to visibility range."

set_number(Value=Index, Number=1, Result=$A)
memory_get(Index=$A, Value=$F1)
set_number(Value=Index, Number=2, Result=$A)
memory_get(Index=$A, Value=$F2)
set_number(Value=Index, Number=3, Result=$A)
memory_get(Index=$A, Value=$F3)
get_closest_entity(Filter=$F1, Filter2=$F2, Filter3=$F3, Output=$R)
is_empty(Value=$R)  >NEXT (Empty) >set_reg (Has Value)
is_empty(Value=Radar)  >NEXT (Empty) >simulation_tick (Has Value)
set_reg:
set_reg(Value=$R, Target=Result)
set_reg(Value=Next Tag, Target=Tag)  >POP (next)
simulation_tick:
simulation_tick(Tick=$Tick)
check_number(Value=$Tick, Compare=Next Tick)  >NEXT (If Larger) >POP (If Smaller) >NEXT (If Equal)
  cmt="""Have enough ticks passed since we setup the radar for it to have gotten a result?""";
set_number(Value=Radar, Number=4, Result=$A)
get_comp_reg(From=$A, Value=$R)
  cmt="""Read any pending result""";
add(To=Next Tick, Num=Radar, Result=Next Tick)  >set_reg (next)
  cmt="""Compute the tick after which the radar will have another result""";