behavior Pickup(Home, State*, Target*, Health Point):

unlock()
wait(Time=1)
sequence()  >NEXT (First) >has_like_component (Second) >POP (Third) >POP (Fourth) >jump (Last)
check_health()  >POP (Full) >NEXT (next)
set_reg(Value=v_enemy_faction, Target=State)
last()
has_like_component:
has_like_component(Component=c_alien_stealth)  >NEXT (Failed) >POP (next)
get_closest_entity(Filter=v_enemy_faction, Output=$A)
set_reg(Value=$A, Target=@signal)
compare_item(Value 1=$A)  >NEXT (If Different) >POP (If Equal)
set_reg(Value=v_enemy_faction, Target=State)
last()
jump:
jump(Label=State)
get_inventory_item()  >set_reg (No Items) >NEXT (next)
set_reg(Value=v_arrow_down, Target=State)  >POP (next)
set_reg:
set_reg(Value=c_portable_radar, Target=State)  >POP (next)
label_portable_radar:
label(Label=c_portable_radar)
  cmt="""Search""";
get_closest_entity(Filter=v_droppeditem, Output=Target)
compare_item(Value 1=Target)  >compare_item (If Different) >NEXT (If Equal)
set_reg(Value=0, Target=$N)
for_signal_match(Signal=v_droppeditem, Signal2=$A)  >compare_item (Done) >NEXT (next)
random_number(Min=0, Max=10000, Result=$B)
check_number(Value=$N, Compare=$B)  >POP (If Larger) >NEXT (If Smaller) >NEXT (If Equal)
set_reg(Value=$B, Target=$N)
set_reg(Value=$A, Target=Target)  >POP (next)
compare_item:
compare_item(Value 1=Target)  >checkfreespace (If Different) >NEXT (If Equal)
get_inventory_item()  >POP (No Items) >NEXT (next)
set_reg(Value=v_arrow_down, Target=State)  >POP (next)
checkfreespace:
checkfreespace(Item=Target)  >set_reg_2 (Can't Fit) >NEXT (next)
set_reg(Value=v_arrow_up, Target=State)  >POP (next)
set_reg_2:
set_reg(Value=v_arrow_down, Target=State)  >POP (next)
label_arrow_down:
label(Label=v_arrow_down)
  cmt="""Drop off""";
set_reg(Value=Home, Target=@goto)
dodrop(Destination=Home)  >POP (Path Blocked) >NEXT (next)
get_inventory_item()  >NEXT (No Items) >POP (next)
compare_item(Value 1=Target)  >set_reg_3 (If Different) >NEXT (If Equal)
set_reg(Value=c_portable_radar, Target=State)  >POP (next)
set_reg_3:
set_reg(Value=v_arrow_up, Target=State)  >POP (next)
label_arrow_up:
label(Label=v_arrow_up)
  cmt="""Pick up""";
checkfreespace(Item=Target)  >set_reg_4 (Can't Fit) >NEXT (next)
set_reg(Value=Target, Target=@goto)
compare_item(Value 1=Target)  >POP (If Different) >NEXT (If Equal)
set_reg(Value=c_portable_radar, Target=State)  >POP (next)
set_reg_4:
set_reg(Value=v_arrow_down, Target=State)  >POP (next)
label_enemy_faction:
label(Label=v_enemy_faction)
  cmt="""Pick up""";
set_reg(Value=Health Point, Target=@goto)
set_reg(Target=Target)
is_moving()  >NEXT (Not Moving) >NEXT (Path Blocked) >POP (No Result) >POP (Moving)
check_health()  >NEXT (Full) >POP (next)
set_reg(Value=v_arrow_down, Target=State)  >POP (next)