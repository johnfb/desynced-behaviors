behavior Healer(Target*, Range):
  keepvars: true

unlock()
wait(Time=1)
get_closest_entity(Filter=v_enemy_faction, Output=$A)
is_empty(Value=$A)  >NEXT (Empty) >label_landingpod (Has Value)
value_type(Data=Target)  >set_reg (Item) >check_health (Unit) >set_reg (Component) >set_reg (Tech) >set_reg (Value) >set_reg (Coord) >NEXT (No Match)
get_closest_entity(Filter=v_damaged, Filter2=v_own_faction, Output=Target)
is_empty(Value=Target)  >NEXT (Empty) >set_number (Has Value)
for_signal_match(Signal=v_damaged, Signal2=$Signal)  >is_empty (Done) >NEXT (next)
match(Unit=$Signal, Filter=v_own_faction)  >POP (Failed) >NEXT (next)
get_distance(Target=$Signal, Distance=$Signal)
check_number(Value=Target, Compare=$Signal)  >POP (If Larger) >NEXT (If Smaller) >NEXT (If Equal)
set_reg(Value=$Signal, Target=Target)  >POP (next)
is_empty:
is_empty(Value=Target)  >NEXT (Empty) >set_number (Has Value)
get_closest_entity(Filter=v_infected, Filter2=v_own_faction, Output=Target)
is_empty(Value=Target)  >NEXT (Empty) >set_number (Has Value)
for_signal_match(Signal=v_infected, Signal2=$Signal)  >is_empty_2 (Done) >NEXT (next)
match(Unit=$Signal, Filter=v_own_faction)  >POP (Failed) >NEXT (next)
get_distance(Target=$Signal, Distance=$Signal)
check_number(Value=Target, Compare=$Signal)  >POP (If Larger) >NEXT (If Smaller) >NEXT (If Equal)
set_reg(Value=$Signal, Target=Target)  >POP (next)
is_empty_2:
is_empty(Value=Target)  >NEXT (Empty) >set_number (Has Value)
add(To=$Count, Num=1, Result=$Count)
check_number(Value=$Count, Compare=100)  >NEXT (If Larger) >POP (If Smaller) >POP (If Equal)
gethome(Result=$Home)
get_self(Unit Reference=$Self)
is_same_grid(Unit=$Home, Unit2=$Self)  >jump (Different) >NEXT (Same Grid)
random_coordinate(Coordinate=$Self, Range=Range, Result=@goto)
set_reg(Value=0, Target=$Count)  >POP (next)
jump:
jump(Label=f_landingpod)  >POP (next) >label_landingpod (jumpâ†’label)
set_number:
set_number(Value=Target, Number=Range, Result=@goto)
set_reg(Value=0, Target=$Count)  >POP (next)
set_reg:
set_reg(Target=Target)  >POP (next)
check_health:
check_health(Unit=Target)  >NEXT (Full) >set_number (next)
set_reg(Target=@goto)
set_reg(Target=Target)  >POP (next)
label_landingpod:
label(Label=f_landingpod)
gethome(Result=$Home)
set_number(Value=$Home, Number=Range, Result=@goto)
set_reg(Target=Target)
set_reg(Value=0, Target=$Count)  >POP (next)